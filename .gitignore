# Python
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/
build/

# VM directory (large disk images, transient state)
vm/

# Windows ISO
*.iso

# QEMU temp
*.ppm

# OS
.DS_Store
Thumbs.db

# ckb-next is a reference checkout (has its own git repo)
ckb-next/

# Stray images in root (use pics/ directory instead)
/*.jpg
/*.png

# Firmware binaries (do not redistribute vendor firmware)
firmware/
*.zip
*.bin

# Raw resource/factory dumps
resource_dumps/
factory_dumps/

# Intermediate decoder output (keep curated images only)
output/*.ppm
output/*_indices.png

# Editor
*.swp
*.swo
*~
.vscode/
.idea/
